# Prisma generated client (regenerated on install)
**/prisma/generated/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test coverage
coverage/
**/coverage/
